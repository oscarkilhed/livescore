# Server Configuration
# Port for the Express server
PORT=3000

# SSI API Configuration
# GraphQL endpoint
GRAPHQL_API_URL=https://shootnscoreit.com/graphql/
# Required: SSI API key sent as x-api-key
GRAPHQL_API_KEY=your-ssi-api-key
# Optional: if SSI requires authenticated user context
# GRAPHQL_AUTH_TOKEN=your-bearer-token
# GRAPHQL_SESSION_COOKIE=sessionid=...
# Optional: JWT login credentials (if you want server-managed token/refresh flow)
# GRAPHQL_AUTH_USERNAME=your-ssi-username
# GRAPHQL_AUTH_PASSWORD=your-ssi-password

# Cache Configuration
# GraphQL cache settings
GRAPHQL_CACHE_MAX_AGE_MS=259200000
GRAPHQL_CACHE_IDLE_EVICTION_MS=3600000
RESPONSE_CACHE_TTL_MS=5000

# Fetch Timeout Configuration
# Timeout for GraphQL requests in milliseconds
GRAPHQL_TIMEOUT=60000

# Node Environment
# Options: development, production, test
NODE_ENV=development

# Feature Flags
# Enable ESS (ECM text parsing) feature
# Set to 'true' or '1' to enable, 'false' or '0' to disable
ESS_FEATURE_ENABLED=false
