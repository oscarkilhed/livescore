# Server Configuration
# Port for the Express server
PORT=3000

# SSI API Configuration
# GraphQL endpoint
# For local development with mock API, use:
#   GRAPHQL_API_URL=http://localhost:3001/graphql/
#   GRAPHQL_API_KEY=mock-key
GRAPHQL_API_URL=https://shootnscoreit.com/graphql/
# Required: SSI API key sent as x-api-key
GRAPHQL_API_KEY=your-ssi-api-key
# Optional: if SSI requires authenticated user context
# GRAPHQL_AUTH_TOKEN=your-bearer-token
# GRAPHQL_SESSION_COOKIE=sessionid=...
# Optional: JWT login credentials (if you want server-managed token/refresh flow)
# GRAPHQL_AUTH_USERNAME=your-ssi-username
# GRAPHQL_AUTH_PASSWORD=your-ssi-password

# Cache Configuration
# GraphQL cache settings
GRAPHQL_CACHE_MAX_AGE_MS=259200000
# Evict an event from the in-memory cache after this long with no requests (6 hours)
GRAPHQL_CACHE_IDLE_EVICTION_MS=21600000
# Short burst cache in front of the API, per event (30 seconds)
RESPONSE_CACHE_TTL_MS=30000

# Fetch Timeout Configuration
# Timeout for GraphQL requests in milliseconds
GRAPHQL_TIMEOUT=60000

# Node Environment
# Options: development, production, test
NODE_ENV=development

# Monitoring (OpenTelemetry -> Grafana Cloud)
# Metrics + logs are pushed directly over OTLP (http/protobuf). Monitoring is
# OFF unless MONITORING_ENABLED is not 'false' AND an OTLP endpoint is set AND
# NODE_ENV is not 'test'. Leave the endpoint blank to keep it disabled.
MONITORING_ENABLED=true
# Base OTLP endpoint from your Grafana Cloud stack's "OTLP" connection page.
# The exporters append /v1/metrics and /v1/logs automatically.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-<zone>.grafana.net/otlp
# Basic auth: base64("<instanceID>:<token>"). Generate with:
#   echo -n '<instanceID>:<token>' | base64
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64 of instanceID:token>
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Resource attributes shown on every metric/log series.
OTEL_SERVICE_NAME=livescore-server
OTEL_DEPLOYMENT_ENVIRONMENT=development
# How often (ms) metrics are pushed. Default 60000.
# OTEL_METRIC_EXPORT_INTERVAL_MS=60000
